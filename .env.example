# Configure the FastAPI host and docs URL for the Streamlit UI.
# Use the deployed API host when your FastAPI app is hosted separately.
# Example values for Render:
# FASTAPI_BASE_URL=https://jenkins-dummy-api.onrender.com
# FASTAPI_DOCS_URL=/docs

FASTAPI_BASE_URL=https://jenkins-dummy-api.onrender.com
FASTAPI_DOCS_URL=/docs
